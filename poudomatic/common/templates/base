## -*- mode: makefile -*-

% block header
PORTNAME=	{{ portname|makevar }}
CATEGORIES=	{{ category|makevar }}
PORTVERSION=	{% filter makevar %}{% block portversion %}{% endblock %}{% endfilter %}
PORTREVSION=	{% filter makevar %}{% block portrevision %}0{% endblock %}{% endfilter %}

MAINTAINER=	{% filter makevar %}{% block maintainer %}poudomatic{% endblock %}{% endfilter %}
COMMENT=	{% filter makevar %}{% block comment %}{% endblock %}{% endfilter %}
LICENSE=	{% filter makevar %}{% block license %}APACHE20{% endblock %}{% endfilter %}
% endblock

% block options
% endblock

.include <bsd.port.options.mk>

PKG_NOTES+=			poudomatic_collection
PKG_NOTE_poudomatic_collection=	{{ collection.uri|makevar }}

% if collection.is_git
PKG_NOTES+=			poudomatic_gitsha
PKG_NOTE_poudomatic_gitsha=	{{ collection.gitsha|makevar }}
% endif

%- macro with_modifier(dep, modifier)
%-   if modifier == "python"
${PYTHON_PKGNAMEPREFIX}{{ dep }}@${PY_FLAVOR}
%-   else
{{ dep }}
%-   endif
%- endmacro

% block depends
%   for dep in rendervars.depends.run_depends
RUN_DEPENDS+=	{{ with_modifier(dep.DEPENDS, dep.modifier)|makevar }}
%   endfor
% endblock

% block users
%   if rendervars.groups
%     script pre_install
%       block install_groups_sh
%         include "install_groups.sh"
%       endblock
%     endscript
%   endif
%   if rendervars.users
%     script pre_install
%       block install_users_sh
%         include "install_users.sh"
%       endblock
%     endscript
%     script post_deinstall
%       block deinstall_users_sh
%         include "deinstall_users.sh"
%       endblock
%     endscript
%   endif
%   if rendervars.groups
%     script post_deinstall
%       block deinstall_groups_sh
%         include "deinstall_groups.sh"
%       endblock
%     endscript
%   endif
% endblock

% block fetch
DISTFILES=

extract:
do-fetch:
	@test -d ${WRKSRC} || \
	     cp -r /usr/ports/{{ fetchdir|shquote }} ${WRKSRC}
% endblock

post-patch:
% block post_patch
%   block post_patch_substitute
%     for type,src,dest,patterns in rendervars.install if patterns
%       set args
%         for pattern,replacement in patterns
-e 's@{{ pattern|replace("@", "\@") }}@{{ replacement|replace("@", "\@") }}@g' {# -#}
%         endfor
%       endset
	@${REINPLACE_CMD} {{ args }} ${WRKSRC}/{{ src|shquote }}
%     endfor
%   endblock
% endblock

post-install:
% block post_install
% for type,src,dest,substitute in rendervars.install
	${MKDIR} {{ into_stagedir(dest|dirname) }}
%   if type == "symlink"
	${RLN} {{ into_stagedir(src) }} {{ into_stagedir(dest) }}
%   else
	{{ INSTALL_MACROS[type] }} ${WRKSRC}/{{ src|shquote }} {{ into_stagedir(dest) }}
%   endif
% endfor
% endblock

% set INSTALL_MACROS = {
          "script": "${INSTALL_SCRIPT}",
          "binary": "${INSTALL_PROGRAM}",
          "data":   "${INSTALL_DATA}",
          "man":    "${INSTALL_MAN}",
      }

% macro into_stagedir(path)
${STAGEDIR}
{%- if path[0] == "/" -%}
  {{ path|shquote }}
{%- else -%}
  ${PREFIX}/{{ path|shquote }}
{%- endif -%}
% endmacro

.include <bsd.port.mk>
